# Backend - Variáveis de Ambiente

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=seu_password_seguro
POSTGRES_DB=terceirogestor

# Node
NODE_ENV=production
PORT=3001

# Segurança
JWT_SECRET=sua_jwt_secret_key_aqui
TOTP_ENCRYPTION_KEY=sua_totp_key_aqui
PII_MASTER_KEY=sua_pii_key_aqui

# App
APP_NAME=Terceiro Gestor
WEB_URL=http://localhost
TZ=America/Sao_Paulo

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@terceirogestor.local

# OAuth Google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/api/registration/oauth/google/callback

# OAuth Microsoft
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost/api/registration/oauth/microsoft/callback
