  effortPoints  Int?
  tags          Json?
  internalNotes String?               @db.Text
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant                Tenant                        @relation(fields: [tenantId], references: [id])
  ownerUser             User?                         @relation("TaskOrganizerAssignedUser", fields: [ownerUserId], references: [id], onDelete: SetNull)
  checklistItems        TaskOrganizerChecklistItem[]
  subtasks              TaskOrganizerSubtask[]
  comments              TaskOrganizerComment[]
  attachments           TaskOrganizerAttachment[]
  blockedByDependencies TaskOrganizerTaskDependency[] @relation("TaskOrganizerTaskBlockedBy")
  dependentTaskLinks    TaskOrganizerTaskDependency[] @relation("TaskOrganizerTaskBlocks")

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@index([tenantId, kind])
  @@index([tenantId, owner])
  @@index([ownerUserId])
  @@index([startDate])
  @@index([dueDate])
}

model TaskOrganizerAttachment {
  id               String   @id @default(uuid()) @db.Char(36)
  tenantId         String   @db.Char(36)
  taskId           String   @db.Char(36)
  uploadedByUserId String?  @db.Char(36)
  label            String
  filePath         String
  mimeType         String?
  fileSizeBytes    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  task           TaskOrganizerTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedByUser User?             @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId, createdAt])
  @@index([uploadedByUserId])
}

model TaskOrganizerChecklistItem {
  id          String    @id @default(uuid()) @db.Char(36)
  tenantId    String    @db.Char(36)
  taskId      String    @db.Char(36)
  label       String
  done        Boolean   @default(false)
  owner       String?
  ownerUserId String?   @db.Char(36)
  dueDate     DateTime?
  notes       String?   @db.Text
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  task      TaskOrganizerTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  ownerUser User?             @relation("TaskOrganizerChecklistAssignedUser", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId, sortOrder])
  @@index([ownerUserId])
}

model TaskOrganizerSubtask {
  id          String              @id @default(uuid()) @db.Char(36)
  tenantId    String              @db.Char(36)
  taskId      String              @db.Char(36)
  title       String
  status      TaskOrganizerStatus @default(BACKLOG)
  owner       String?
  ownerUserId String?             @db.Char(36)
  startDate   DateTime?
  dueDate     DateTime?
  description String?             @db.Text
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id])
  task      TaskOrganizerTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  ownerUser User?             @relation("TaskOrganizerSubtaskAssignedUser", fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId, sortOrder])
  @@index([ownerUserId])
}

model TaskOrganizerComment {
  id             String   @id @default(uuid()) @db.Char(36)
  tenantId       String   @db.Char(36)
  taskId         String   @db.Char(36)
  authorUserId   String?  @db.Char(36)
  body           String   @db.Text
  mentionUserIds Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant            @relation(fields: [tenantId], references: [id])
  task       TaskOrganizerTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorUser User?             @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([taskId, createdAt])
  @@index([authorUserId])
}

model TaskOrganizerTaskDependency {
  id              String   @id @default(uuid()) @db.Char(36)
  tenantId        String   @db.Char(36)
  taskId          String   @db.Char(36)
  dependsOnTaskId String   @db.Char(36)
  createdAt       DateTime @default(now())

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  task          TaskOrganizerTask @relation("TaskOrganizerTaskBlockedBy", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOnTask TaskOrganizerTask @relation("TaskOrganizerTaskBlocks", fields: [dependsOnTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnTaskId])
  @@index([tenantId])
  @@index([taskId])
  @@index([dependsOnTaskId])
}

model TenantRegistration {
  id     String                   @id @default(uuid()) @db.Char(36)
  method TenantRegistrationMethod
  status TenantRegistrationStatus @default(PENDING_VERIFICATION)

  tenantName String
  tenantSlug String

  adminName         String?
  adminEmail        String?
  adminPasswordHash String?

  oauthProviderSub String?
  oauthStateHash   String?

  verificationCodeHash      String?
  verificationCodeExpiresAt DateTime?

  tenantId    String?   @db.Char(36)
  adminUserId String?   @db.Char(36)
  confirmedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([adminEmail])
  @@index([tenantSlug])
  @@index([status])
  @@index([createdAt])
}

model UserMfaTotpSetup {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  userId    String   @db.Char(36)
  secretEnc String   @db.Text
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
}

model UserMfaChallenge {
  id         String    @id @default(uuid()) @db.Char(36)
  tenantId   String    @db.Char(36)
  userId     String    @db.Char(36)
  type       String
  attempts   Int       @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
}

model UserTrustedDevice {
  id         String    @id @default(uuid()) @db.Char(36)
  tenantId   String    @db.Char(36)
  userId     String    @db.Char(36)
  tokenHash  String    @db.VarChar(128)
  label      String?
  ipAddress  String?
  userAgent  String?
  lastUsedAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, tokenHash])
  @@index([tenantId])
  @@index([userId])
  @@index([expiresAt])
}

model UserMfaRecoveryCode {
  id        String    @id @default(uuid()) @db.Char(36)
  tenantId  String    @db.Char(36)
  userId    String    @db.Char(36)
  codeHash  String    @db.VarChar(128)
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, codeHash])
  @@index([tenantId])
  @@index([userId])
}
