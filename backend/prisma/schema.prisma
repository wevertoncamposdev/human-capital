generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum ProgramType {
  SCFV
  PAIF
  PAEFI
  CULTURAL
  QUALIFICATION
  OTHER
}

enum ProgramStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  CLOSED
}

enum EnrollmentStatus {
  ACTIVE
  ENDED
}

enum ProjectParticipationRole {
  PUBLICO_ATENDIDO
  FAMILIAR
  VOLUNTARIO
  EQUIPE_TECNICA
  FUNCIONARIO
  OFICINEIRO
  PARCEIRO
  DOADOR
  PATROCINADOR
}

enum ParticipationKind {
  PARTICIPANT
  TEAM
}

enum PeopleGroupType {
  CYCLE
  SEGMENT
  TEAM_POOL
  NETWORK
  OTHER
}

enum PeopleGroupPurpose {
  PUBLICO
  EQUIPE
}

enum ActionStatus {
  PLANNED
  EXECUTED
  CANCELED
}

enum ActionTarget {
  PROJECT
  PROJECT_GROUP
  PEOPLE_GROUP
  ENROLLMENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  EXCUSED
}

enum ActionPeopleParticipationRole {
  PARTICIPANTE
  FACILITADOR
  APOIO
  VOLUNTARIO
  RESPONSAVEL_TECNICO
  CONVIDADO
}

enum IncomeFrequency {
  MONTHLY
  WEEKLY
  BIWEEKLY
  ANNUAL
  ONCE
}

enum PersonFinancialEntryType {
  INCOME
  EXPENSE
  TRANSFER
  BENEFIT
}

enum AccessLogAction {
  LOGIN
  REFRESH
  LOGOUT
}

enum AuditLogAction {
  CREATE
  UPDATE
  DELETE
}

enum PantryDonorType {
  PERSON
  COMPANY
}

enum PantryExitType {
  ATTENDED
  DONATION
  EVENT
  PARTY
  CORRECTION
}

enum DepositDonorType {
  PERSON
  COMPANY
}

enum DepositExitType {
  LOAN
  FINAL_REMOVAL
  TRANSFER
  ADJUSTMENT
  LOSS
}

enum TaskOrganizerStatus {
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  DONE
  BLOCKED
}

enum TaskOrganizerPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskOrganizerKind {
  FEATURE
  BUG
  ROUTINE
}

enum TenantRegistrationMethod {
  EMAIL
  GOOGLE
  MICROSOFT
}

enum TenantRegistrationStatus {
  PENDING_OAUTH
  PENDING_VERIFICATION
  CONFIRMED
  EXPIRED
}

enum PersonContactType {
  EMAIL
  PHONE
}

enum PersonContactRole {
  SELF
  RESPONSIBLE
  EMERGENCY
}

enum SensitiveAccessAction {
  READ
  UPDATE
}

model Tenant {
  id          String       @id @default(uuid()) @db.Char(36)
  name        String       @unique
  slug        String       @unique
  logoUrl     String?
  cnpj        String?
  startYear   Int?
  description String?      @db.Text
  status      TenantStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  users                                User[]
  roles                                Role[]
  mfaTotpSetups                        UserMfaTotpSetup[]
  mfaChallenges                        UserMfaChallenge[]
  trustedDevices                       UserTrustedDevice[]
  mfaRecoveryCodes                     UserMfaRecoveryCode[]
  people                               Person[]
  peopleGroups                         PeopleGroup[]
  peopleGroupParticipations            PeopleGroupParticipation[]
  peopleSegments                       PeopleSegment[]
  peopleSegmentMemberships             PeopleSegmentMembership[]
  personContacts                       PersonContact[]
  personComments                       PersonComment[]
  personAttachments                    PersonAttachment[]
  personRecordComments                 PersonRecordComment[]
  personRecordAttachments              PersonRecordAttachment[]
  personRecordTags                     PersonRecordTag[]
  personSensitiveDocuments             PersonSensitiveDocument[]
  personSensitiveAccessLogs            PersonSensitiveAccessLog[]
  rolePermissions                      RolePermission[]
  userRoles                            UserRole[]
  households                           Household[]
  householdMembers                     HouseholdMember[]
  householdProfiles                    HouseholdProfile[]
  personRelations                      PersonRelation[]
  personFinancialEntries               PersonFinancialEntry[]
  personIncomes                        PersonIncome[]
  personExpenses                       PersonExpense[]
  personBenefits                       PersonBenefit[]
  personDetentions                     PersonDetention[]
  householdAssets                      HouseholdAsset[]
  personAssets                         PersonAsset[]
  householdTransfers                   HouseholdTransfer[]
  personHealthConditions               PersonHealthCondition[]
  personMedications                    PersonMedication[]
  personEducations                     PersonEducation[]
  userSessions                         UserSession[]
  passwordResetTokens                  PasswordResetToken[]
  accessLogs                           AccessLog[]
  auditLogs                            AuditLog[]
  pantryItems                          PantryItem[]
  pantrySectors                        PantrySector[]
  pantryEntries                        PantryEntry[]
  pantryExits                          PantryExit[]
  pantryDonors                         PantryDonor[]
  pantryItemComments                   PantryItemComment[]
  pantryItemAttachments                PantryItemAttachment[]
  pantryDonorComments                  PantryDonorComment[]
  pantryDonorAttachments               PantryDonorAttachment[]
  pantryEntryComments                  PantryEntryComment[]
  pantryEntryAttachments               PantryEntryAttachment[]
  pantryExitComments                   PantryExitComment[]
  pantryExitAttachments                PantryExitAttachment[]
  pantryExitAllocations                PantryExitAllocation[]
  depositItems                         DepositItem[]
  depositSectors                       DepositSector[]
  depositEntries                       DepositEntry[]
  depositExits                         DepositExit[]
  depositDonors                        DepositDonor[]
  depositItemComments                  DepositItemComment[]
  depositItemAttachments               DepositItemAttachment[]
  depositDonorComments                 DepositDonorComment[]
  depositDonorAttachments              DepositDonorAttachment[]
  depositEntryComments                 DepositEntryComment[]
  depositEntryAttachments              DepositEntryAttachment[]
  depositExitComments                  DepositExitComment[]
  depositExitAttachments               DepositExitAttachment[]
  depositExitAllocations               DepositExitAllocation[]
  taskOrganizerTasks                   TaskOrganizerTask[]
  taskOrganizerChecklistItems          TaskOrganizerChecklistItem[]
  taskOrganizerSubtasks                TaskOrganizerSubtask[]
  taskOrganizerComments                TaskOrganizerComment[]
  taskOrganizerAttachments             TaskOrganizerAttachment[]
  taskOrganizerTaskDependencies        TaskOrganizerTaskDependency[]
  programs                             Program[]
  projects                             Project[]
  projectComments                      ProjectComment[]
  projectAttachments                   ProjectAttachment[]
  programComments                      ProgramComment[]
  programAttachments                   ProgramAttachment[]
  projectGroups                        ProjectGroup[]
  projectPeopleGroups                  ProjectPeopleGroup[]
  projectEnrollments                   ProjectEnrollment[]
  projectEnrollmentGroupMemberships    ProjectEnrollmentGroupMembership[]
  actionTypes                          ActionType[]
  projectActions                       ProjectAction[]
  projectActionComments                ProjectActionComment[]
  projectActionAttachments             ProjectActionAttachment[]
  actionPeopleGroups                   ActionPeopleGroup[]
  projectActionAttendances             ProjectActionAttendance[]
  projectActionPeopleParticipations    ProjectActionPeopleParticipation[]

  @@index([status])
}

model User {
  id                String    @id @default(uuid()) @db.Char(36)
  tenantId          String    @db.Char(36)
  name              String?
  email             String
  phone             String?
  bio               String?   @db.Text
  passwordHash      String
  avatarUrl         String?
  isActive          Boolean   @default(true)
  mfaTotpEnabled    Boolean   @default(false)
  mfaTotpSecretEnc  String?   @db.Text
  mfaTotpVerifiedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant                              Tenant                       @relation(fields: [tenantId], references: [id])
  roles                               UserRole[]
  sessions                            UserSession[]
  passwordResetTokens                 PasswordResetToken[]
  accessLogs                          AccessLog[]
  auditLogs                           AuditLog[]
  mfaTotpSetups                       UserMfaTotpSetup[]
  mfaChallenges                       UserMfaChallenge[]
  trustedDevices                      UserTrustedDevice[]
  recoveryCodes                       UserMfaRecoveryCode[]
  personSensitiveAccessLogs           PersonSensitiveAccessLog[]
  personComments                      PersonComment[]
  personAttachments                   PersonAttachment[]
  personRecordComments                PersonRecordComment[]
  personRecordAttachments             PersonRecordAttachment[]
  pantryItemComments                  PantryItemComment[]
  pantryItemAttachments               PantryItemAttachment[]
  pantryDonorComments                 PantryDonorComment[]
  pantryDonorAttachments              PantryDonorAttachment[]
  pantryEntryComments                 PantryEntryComment[]
  pantryEntryAttachments              PantryEntryAttachment[]
  pantryExitComments                  PantryExitComment[]
  pantryExitAttachments               PantryExitAttachment[]
  depositItemComments                 DepositItemComment[]
  depositItemAttachments              DepositItemAttachment[]
  depositDonorComments                DepositDonorComment[]
  depositDonorAttachments             DepositDonorAttachment[]
  depositEntryComments                DepositEntryComment[]
  depositEntryAttachments             DepositEntryAttachment[]
  depositExitComments                 DepositExitComment[]
  depositExitAttachments              DepositExitAttachment[]
  projectActionsCreated               ProjectAction[]
  projectComments                     ProjectComment[]
  projectAttachments                  ProjectAttachment[]
  programComments                     ProgramComment[]
  programAttachments                  ProgramAttachment[]
  projectActionComments               ProjectActionComment[]
  projectActionAttachments            ProjectActionAttachment[]
  assignedTaskOrganizerTasks          TaskOrganizerTask[]          @relation("TaskOrganizerAssignedUser")
  assignedTaskOrganizerChecklistItems TaskOrganizerChecklistItem[] @relation("TaskOrganizerChecklistAssignedUser")
  assignedTaskOrganizerSubtasks       TaskOrganizerSubtask[]       @relation("TaskOrganizerSubtaskAssignedUser")
  taskOrganizerComments               TaskOrganizerComment[]
  taskOrganizerAttachments            TaskOrganizerAttachment[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(uuid()) @db.Char(36)
  tenantId    String   @db.Char(36)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String   @id @default(uuid()) @db.Char(36)
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Char(36)
  tenantId     String   @db.Char(36)
  roleId       String   @db.Char(36)
  permissionId String   @db.Char(36)
  createdAt    DateTime @default(now())

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([tenantId, roleId, permissionId])
  @@index([tenantId])
}

model UserRole {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  userId    String   @db.Char(36)
  roleId    String   @db.Char(36)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
}

model Person {
  id              String    @id @default(uuid()) @db.Char(36)
  tenantId        String    @db.Char(36)
  fullName        String
  birthDate       DateTime?
  socialName      String?
  sex             String?
  gender          String?
  raceColor       String?
  maritalStatus   String?
  nationality     String?
  email           String?
  phone           String?
  document        String?
  rg              String?
  nis             String?
  personType      String    @default("Atendido")
  status          String?
  departureReason String?   @db.Text
  tags            String?   @db.Text
  notes           String?   @db.Text
  profileSummary  String?   @db.Text
  avatarUrl       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant                     Tenant                             @relation(fields: [tenantId], references: [id])
  householdMembers           HouseholdMember[]
  relations                  PersonRelation[]                   @relation("PersonRelationPerson")
  relatedRelations           PersonRelation[]                   @relation("PersonRelationRelated")
  financialEntries           PersonFinancialEntry[]
  incomes                    PersonIncome[]
  expenses                   PersonExpense[]
  benefits                   PersonBenefit[]
  detentions                 PersonDetention[]
  assets                     PersonAsset[]
  transfers                  HouseholdTransfer[]
  healthConditions           PersonHealthCondition[]
  medications                PersonMedication[]
  educations                 PersonEducation[]
  contacts                   PersonContact[]
  comments                   PersonComment[]
  attachments                PersonAttachment[]
  recordComments             PersonRecordComment[]
  recordAttachments          PersonRecordAttachment[]
  recordTags                 PersonRecordTag[]
  sensitiveDocument          PersonSensitiveDocument?
  sensitiveAccessLogs        PersonSensitiveAccessLog[]
  projectEnrollments         ProjectEnrollment[]
  peopleGroupParticipations  PeopleGroupParticipation[]
  peopleSegmentMemberships   PeopleSegmentMembership[]
  actionPeopleParticipations ProjectActionPeopleParticipation[]

  @@index([tenantId])
  @@index([fullName])
}

model PersonContact {
  id           String            @id @default(uuid()) @db.Char(36)
  tenantId     String            @db.Char(36)
  personId     String            @db.Char(36)
  role         PersonContactRole @default(SELF)
  type         PersonContactType
  label        String?
  name         String?
  relationship String?
  value        String
  isPrimary    Boolean           @default(false)
  isWhatsapp   Boolean           @default(false)
  notes        String?           @db.Text
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@unique([tenantId, personId, type, value])
  @@index([tenantId])
  @@index([personId])
  @@index([tenantId, personId, type])
}

model PersonComment {
  id             String   @id @default(uuid()) @db.Char(36)
  tenantId       String   @db.Char(36)
  personId       String   @db.Char(36)
  authorUserId   String?  @db.Char(36)
  body           String   @db.Text
  mentionUserIds Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  person     Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  authorUser User?  @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([personId, createdAt])
  @@index([authorUserId])
}

model PersonAttachment {
  id               String   @id @default(uuid()) @db.Char(36)
  tenantId         String   @db.Char(36)
  personId         String   @db.Char(36)
  uploadedByUserId String?  @db.Char(36)
  label            String
  filePath         String
  mimeType         String?
  fileSizeBytes    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id])
  person         Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  uploadedByUser User?  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([personId, createdAt])
  @@index([uploadedByUserId])
}

model PersonRecordComment {
  id             String   @id @default(uuid()) @db.Char(36)
  tenantId       String   @db.Char(36)
  personId       String   @db.Char(36)
  recordType     String   @db.VarChar(64)
  recordId       String   @db.Char(36)
  authorUserId   String?  @db.Char(36)
  body           String   @db.Text
  mentionUserIds Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  person     Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  authorUser User?  @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([personId, recordType, recordId, createdAt], map: "PRComment_record_idx")
  @@index([authorUserId])
}

model PersonRecordAttachment {
  id               String   @id @default(uuid()) @db.Char(36)
  tenantId         String   @db.Char(36)
  personId         String   @db.Char(36)
  recordType       String   @db.VarChar(64)
  recordId         String   @db.Char(36)
  uploadedByUserId String?  @db.Char(36)
  label            String
  filePath         String
  mimeType         String?
  fileSizeBytes    Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id])
  person         Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  uploadedByUser User?  @relation(fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([personId, recordType, recordId, createdAt], map: "PRAttach_record_idx")
  @@index([uploadedByUserId])
}

model PersonRecordTag {
  id         String   @id @default(uuid()) @db.Char(36)
  tenantId   String   @db.Char(36)
  personId   String   @db.Char(36)
  recordType String   @db.VarChar(64)
  recordId   String   @db.Char(36)
  value      String   @db.VarChar(120)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([tenantId, recordType, recordId, value], map: "PRTag_record_value_key")
  @@index([tenantId])
  @@index([personId, recordType, recordId], map: "PRTag_record_idx")
}

model PersonSensitiveDocument {
  id            String   @id @default(uuid()) @db.Char(36)
  tenantId      String   @db.Char(36)
  personId      String   @unique @db.Char(36)
  schemaVersion Int      @default(1)
  dataEnc       Bytes
  iv            Bytes
  tag           Bytes
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
}

model PersonSensitiveAccessLog {
  id        String                @id @default(uuid()) @db.Char(36)
  tenantId  String                @db.Char(36)
  personId  String                @db.Char(36)
  userId    String                @db.Char(36)
  action    SensitiveAccessAction
  ipAddress String?               @db.VarChar(64)
  userAgent String?               @db.Text
  createdAt DateTime              @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([personId])
  @@index([userId])
  @@index([tenantId, personId, action])
}

model Household {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                   Tenant                 @relation(fields: [tenantId], references: [id])
  members                  HouseholdMember[]
  profile                  HouseholdProfile?
  financialEntries         PersonFinancialEntry[]
  outgoingFinancialEntries PersonFinancialEntry[] @relation("PersonFinancialEntryFromHousehold")
  incomingFinancialEntries PersonFinancialEntry[] @relation("PersonFinancialEntryToHousehold")
  assets                   HouseholdAsset[]
  incomes                  PersonIncome[]
  expenses                 PersonExpense[]
  benefits                 PersonBenefit[]
  outgoingTransfers        HouseholdTransfer[]    @relation("HouseholdTransferFrom")
  incomingTransfers        HouseholdTransfer[]    @relation("HouseholdTransferTo")

  @@index([tenantId])
}

model HouseholdMember {
  id                  String    @id @default(uuid()) @db.Char(36)
  tenantId            String    @db.Char(36)
  householdId         String    @db.Char(36)
  personId            String    @db.Char(36)
  role                String?
  isLegalGuardian     Boolean   @default(false)
  isHouseholdHead     Boolean   @default(false)
  isIncomeContributor Boolean   @default(false)
  isProvider          Boolean   @default(false)
  isDependent         Boolean   @default(false)
  notes               String?   @db.Text
  startDate           DateTime?
  endDate             DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  household Household @relation(fields: [householdId], references: [id])
  person    Person    @relation(fields: [personId], references: [id])

  @@unique([householdId, personId])
  @@index([tenantId])
  @@index([householdId])
  @@index([personId])
}

model HouseholdProfile {
  id           String   @id @default(uuid()) @db.Char(36)
  tenantId     String   @db.Char(36)
  householdId  String   @unique @db.Char(36)
  type         String?
  condition    String?
  ownership    String?
  areaM2       Float?
  rooms        Int?
  bathrooms    Int?
  cep          String?  @db.VarChar(8)
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?  @db.VarChar(2)
  ibge         String?  @db.VarChar(7)
  gia          String?
  ddd          String?  @db.VarChar(3)
  siafi        String?  @db.VarChar(4)
  reference    String?  @db.Text
  notes        String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  household Household @relation(fields: [householdId], references: [id])

  @@index([tenantId])
  @@index([tenantId, cep])
}

model HouseholdAsset {
  id          String   @id @default(uuid()) @db.Char(36)
  tenantId    String   @db.Char(36)
  householdId String   @db.Char(36)
  category    String
  item        String
  quantity    Int?     @default(1)
  condition   String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  household Household @relation(fields: [householdId], references: [id])

  @@index([tenantId])
  @@index([householdId])
}

model PersonAsset {
  id        String   @id @default(uuid()) @db.Char(36)
  tenantId  String   @db.Char(36)
  personId  String   @db.Char(36)
  category  String
  item      String
  quantity  Int?     @default(1)
  condition String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  person Person @relation(fields: [personId], references: [id])

  @@index([tenantId])
  @@index([personId])
}

model PersonIncome {
  id                      String          @id @default(uuid()) @db.Char(36)
  tenantId                String          @db.Char(36)
  personId                String          @db.Char(36)
  householdId             String?         @db.Char(36)
  type                    String
  amount                  Decimal         @db.Decimal(10, 2)
  frequency               IncomeFrequency @default(MONTHLY)
  contractType            String?
  isHouseholdContribution Boolean         @default(true)
  notes                   String?         @db.Text
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  person    Person     @relation(fields: [personId], references: [id])
  household Household? @relation(fields: [householdId], references: [id])

  @@index([tenantId])
  @@index([personId])
  @@index([householdId])
}

model PersonFinancialEntry {
  id                       String                   @id @default(uuid()) @db.Char(36)
  tenantId                 String                   @db.Char(36)
  personId                 String                   @db.Char(36)
  householdId              String?                  @db.Char(36)
  fromHouseholdId          String?                  @db.Char(36)
  toHouseholdId            String?                  @db.Char(36)
  entryType                PersonFinancialEntryType
  category                 String
  subcategory              String?
  status                   String?
  amount                   Decimal?                 @db.Decimal(10, 2)
  frequency                IncomeFrequency          @default(MONTHLY)
  contractType             String?
  includeInHouseholdBudget Boolean                  @default(true)
  startDate                DateTime?
  endDate                  DateTime?
  notes                    String?                  @db.Text
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id])
  person        Person     @relation(fields: [personId], references: [id])
  household     Household? @relation(fields: [householdId], references: [id])
  fromHousehold Household? @relation("PersonFinancialEntryFromHousehold", fields: [fromHouseholdId], references: [id])
