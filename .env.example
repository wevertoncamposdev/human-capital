POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-now
POSTGRES_DB=terceirogestor
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=5432

BACKEND_BIND_ADDRESS=0.0.0.0
BACKEND_PORT=3001

FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=3000

# Local docker-compose values.
RUN_DB_PRESTART=true
DATABASE_URL=postgresql://postgres:change-me-now@postgres:5432/terceirogestor
SHADOW_DATABASE_URL=postgresql://postgres:change-me-now@postgres:5432/terceirogestor_shadow
API_INTERNAL_URL=http://backend:8080
FRONTEND_PUBLIC_API_URL=http://localhost:3001
# Compatibility variable used by the frontend build/runtime.
NEXT_PUBLIC_API_URL=http://localhost:3001

APP_NAME=Terceiro Gestor
JWT_SECRET=change-me-now

# Public frontend URL used for redirects and cookie policies.
WEB_URL=http://localhost:3000

NEXT_PUBLIC_PWA_SW=0
NEXT_PUBLIC_PWA_FORCE_INSTALL=0

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@terceirogestor.local

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost/api/registration/oauth/google/callback

MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=http://localhost/api/registration/oauth/microsoft/callback

TZ=America/Sao_Paulo

# Master key (base64) for encrypting PII at rest (CPF/RG/NIS/CNS).
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_MASTER_KEY=""

# 32-byte key (hex 64 chars or base64). Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=""

# ============================================================
# GOOGLE CLOUD PLATFORM (Cloud Run / Cloud SQL / Cloud Storage)
# ============================================================
# Cloud Run backend should use DATABASE_URL from Secret Manager and keep
# RUN_DB_PRESTART=false. Frontend must be built with FRONTEND_PUBLIC_API_URL
# set to the backend public URL or to a load balancer path such as /api.

# Google Cloud Project ID (e.g., "meu-projeto-gcp-123")
GCP_PROJECT_ID=""

# Cloud Storage bucket for file uploads
GCP_BUCKET_NAME=""

# Cloud Storage Signed URL TTL (in seconds)
# HIGH sensitivity (health documents, RG): 5-10 min
GCS_SIGNED_URL_TTL_SENSITIVE=300
# MEDIUM sensitivity (programs, projects): 30 min  
GCS_SIGNED_URL_TTL_MEDIUM=1800
# LOW sensitivity (avatars, logos): 1 hour
GCS_SIGNED_URL_TTL_LOW=3600

# Cloud SQL (PostgreSQL - instead of local postgres in docker-compose)
# For Cloud SQL Proxy: postgresql://user:pass@project:region:instance/database
# Format: postgresql://{user}:{password}@{host}/{database}?sslmode=require
# Cloud Run will inject via Secret Manager in production
CLOUD_SQL_CONNECTION_NAME=""

# Application Default Credentials
# In Cloud Run, this is automatic via service account
# For local testing: GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GOOGLE_APPLICATION_CREDENTIALS=""
